// prisma/schema.prisma

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum TransactionType {
  DEPOSIT
  PURCHASE
  REFUND
  PROMO
  REFERRAL
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
}

enum NumberStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum DiscountType {
  FLAT
  PERCENT
}

enum ActiveStatus {
  ACTIVE
  CLOSED
}

/// User account standing. Always compare with this enum — never raw strings.
enum UserStatus {
  ACTIVE
  BLOCKED
  SUSPENDED
}

// ─── Auth models ──────────────────────────────────────────────────────────────

model User {
  id                    String    @id @default(cuid())
  email                 String?   @unique
  emailVerified         Boolean   @default(false)
  name                  String?
  image                 String?
  telegramId            String    @unique
  telegramUsername      String?
  firstName             String?
  lastName              String?
  languageCode          String?
  isPremium             Boolean?  @default(false)
  allowsWriteToPm       Boolean?  @default(false)
  photoUrl              String?
  addedToAttachmentMenu Boolean?  @default(false)
  authDate              DateTime?
  queryId               String?
  chatInstance          String?
  chatType              String?
  startParam            String?
  canSendAfter          Int?
  isAdmin               Boolean   @default(false)
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  accounts             Account[]
  sessions             Session[]
  wallet               Wallet?
  numbers              ActiveNumber[]
  customPrices         CustomPrice[]
  promoHistory         PromocodeHistory[]
  auditLogsAsTarget    UserAuditLog[]     @relation("AuditTarget")
  auditLogsAsPerformer UserAuditLog[]     @relation("AuditPerformer")
  userApi              UserApi?
  userData             UserData?
}

model Account {
  id               String    @id @default(cuid())
  userId           String
  type             String    @default("oauth")
  providerId       String
  accountId        String
  refreshToken     String?   @default("")
  accessToken      String?   @default("")
  expiresAt        DateTime?
  tokenType        String?   @default("")
  scope            String?   @default("")
  idToken          String?   @default("")
  sessionState     String?   @default("")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  telegramId       String?
  telegramUsername String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  // Poller/cleanup queries filtering expired sessions
  @@index([expiresAt])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@index([expiresAt])
}

// ─── Wallet ───────────────────────────────────────────────────────────────────

model Wallet {
  id            String   @id @default(cuid())
  userId        String   @unique
  /// Non-negative. Enforced by DB CHECK constraint in migration.
  balance       Decimal  @default(0) @db.Decimal(10, 2)
  /// IMPORTANT: totalSpent tracks actual successful purchases with SMS received.
  /// This value represents cumulative purchases where SMS was actually received.
  /// IMPORTANT: totalSpent tracks actual successful purchases with SMS received.
  /// This value represents cumulative purchases where SMS was actually received.
  /// Non-negative. Enforced by DB CHECK constraint in migration.
  totalSpent    Decimal  @default(0) @db.Decimal(10, 2)
  /// IMPORTANT: totalOtp tracks the count of SMS messages received.
  /// This count is incremented when SMS is received, not at purchase time.
  /// Non-negative. Enforced by DB CHECK constraint in migration.
  totalOtp      Int      @default(0)
  /// Non-negative. Enforced by DB CHECK constraint in migration.
  totalRecharge Decimal  @default(0) @db.Decimal(10, 2)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
}

model Transaction {
  id     String @id @default(cuid())
  walletId String

  type   TransactionType
  /// Amount is always positive — sign is implied by type.
  /// Non-negative enforced by DB CHECK constraint in migration.
  amount Decimal           @db.Decimal(10, 2)
  status TransactionStatus @default(COMPLETED)

  description String?
  phoneNumber String?

  /// Dedup key for deposits (UTR). Null for all other transaction types.
  txnId         String? @unique
  /// Dedup key for refunds — stores the source orderId.
  /// Unique constraint prevents duplicate REFUND surviving a poller/cancel race.
  refundOrderId String? @unique

  /// Denormalised orderId for efficient lookup without JSON path scan.
  /// Replaces: metadata->>'orderId' queries (which cannot use a B-tree index).
  /// Set on PURCHASE, REFUND, and PROMO transactions where an orderId exists.
  /// FIX: previously orderId was only buried inside the metadata JSON column,
  /// forcing a full table scan (metadata @> {path: ["orderId"], equals: X}).
  orderId String?

  /// Arbitrary extra data. Do NOT query with path operators — use top-level
  /// columns (orderId, phoneNumber, txnId) for any field you need to filter on.
  metadata Json?

  createdAt DateTime @default(now())
  /// Transactions are append-only — no updatedAt by design.

  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  // ── Pagination indexes ──────────────────────────────────────────────────────
  // Compound (createdAt, id) supports stable cursor pagination:
  //   WHERE (createdAt < $cursor.createdAt)
  //      OR (createdAt = $cursor.createdAt AND id < $cursor.id)
  // Pure createdAt is insufficient — two records can share the same timestamp,
  // causing items to be silently skipped between pages.
  @@index([walletId, createdAt(sort: Desc), id(sort: Desc)])

  // ── Filter indexes ──────────────────────────────────────────────────────────
  @@index([walletId, status])
  @@index([walletId, type])
  // Efficient lookup by orderId (PURCHASE/REFUND metadata update, status checks)
  @@index([orderId])
}

// ─── OTP provider models ──────────────────────────────────────────────────────

model ApiCredential {
  id        String   @id @default(cuid())
  name      String
  apiUrl    String
  /// SECURITY: rotate via admin panel — never commit to source control.
  apiKey    String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  servers OtpServer[]

  @@index([isActive])
}

model OtpServer {
  id          String   @id @default(cuid())
  name        String
  countryCode String
  countryIso  String   @default("IN")
  countryName String   @default("India")
  flagUrl     String?
  apiId       String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  services Service[]
  numbers  ActiveNumber[]
  api      ApiCredential @relation(fields: [apiId], references: [id])

  @@index([apiId])
  @@index([isActive])
}

model Service {
  id        String   @id @default(cuid())
  code      String
  name      String
  serverId  String
  basePrice Decimal  @db.Decimal(10, 2)
  iconUrl   String   @default("https://i.ibb.co/kgBcLZsX/meow.png")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  server       OtpServer     @relation(fields: [serverId], references: [id])
  purchases    ActiveNumber[]
  customPrices CustomPrice[]

  @@unique([code, serverId])
  @@index([isActive])
  @@index([serverId])
  @@index([name])
}

model ActiveNumber {
  id          String @id @default(cuid())
  userId      String
  serviceId   String
  serverId    String

  /// Unique order reference — used as the join key across transactions and provider calls.
  orderId String @unique

  /// Provider-assigned order ID. NULL until provider call succeeds.
  numberId String?

  /// E.164 phone number. NULL until provider call succeeds.
  phoneNumber String?

  /// Purchase price at time of buy.
  /// Non-negative (0.00 allowed for 100% discount). Enforced by DB CHECK.
  price Decimal @db.Decimal(10, 2)

  status       NumberStatus @default(PENDING)
  activeStatus ActiveStatus @default(ACTIVE)

  /// SMS messages received for this number.
  smsMessages SmsMessage[]

  /// True while balance has been deducted and no refund issued.
  balanceDeducted Boolean @default(false)

  /// Provider's raw status string for debugging (e.g., "SUCCESS", "API_ERROR", "TIMEOUT").
  providerStatus    String?
  /// Error message from provider API call, if any.
  providerError     String?
  /// Timestamp of last poller check for this number.
  lastProviderCheck DateTime?

  createdAt DateTime @default(now())
  expiresAt DateTime
  updatedAt DateTime @updatedAt

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service   @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  server  OtpServer @relation(fields: [serverId], references: [id], onDelete: Restrict)

  // ── Pagination indexes ──────────────────────────────────────────────────────
  @@index([userId, activeStatus, status, createdAt(sort: Desc), id(sort: Desc)])

  // ── Poller index ────────────────────────────────────────────────────
  @@index([activeStatus, expiresAt])

  // ── Point-lookup indexes ────────────────────────────────────────────────────
  @@index([orderId, userId])
  @@index([userId, status])
  @@index([serverId])
}

// ─── SMS Messages ────────────────────────────────────────────────────────────

model SmsMessage {
  id             String   @id @default(cuid())
  activeNumberId String
  content        String
  receivedAt     DateTime @default(now())

  activeNumber ActiveNumber @relation(fields: [activeNumberId], references: [id], onDelete: Cascade)

  @@unique([activeNumberId, content])
  @@index([activeNumberId])
  @@index([activeNumberId, receivedAt])
}

// ─── Promotions ───────────────────────────────────────────────────────────────

model Promocode {
  id        String   @id @default(cuid())
  code      String   @unique
  amount    Decimal  @db.Decimal(10, 2)
  maxUses   Int      @default(1)
  usedCount Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  history PromocodeHistory[]

  @@index([isActive])
}

model PromocodeHistory {
  id          String   @id @default(cuid())
  promocodeId String
  userId      String
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())

  promocode Promocode @relation(fields: [promocodeId], references: [id])
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Unique constraint is the authoritative race-safe dedup guard for redeemPromo.
  @@unique([promocodeId, userId])
}

model CustomPrice {
  id        String       @id @default(cuid())
  userId    String
  serviceId String
  discount  Decimal      @db.Decimal(10, 2)
  type      DiscountType

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  service Service @relation(fields: [serviceId], references: [id])

  @@unique([userId, serviceId])
  @@index([serviceId])
}

// ─── Settings ─────────────────────────────────────────────────────────────────

model Settings {
  id String @id @default("1")

  // Payment gateway
  bharatpeMerchantId String?
  bharatpeToken      String?
  bharatpeQrImage    String?
  upiId              String?

  // Recharge limits
  minRechargeAmount Decimal @default(10)   @db.Decimal(10, 2)
  maxRechargeAmount Decimal @default(5000) @db.Decimal(10, 2)

  // Display
  /// Stored as the literal symbol (e.g. "₹", "$"). Not an ISO code.
  currency String @default("₹")

  // Business rules
  referralPercent     Float   @default(0)
  minRedeem           Decimal @default(0)  @db.Decimal(10, 2)
  numberExpiryMinutes Int     @default(15)
  minCancelMinutes    Int     @default(2)

  // Feature flags
  maintenanceMode Boolean @default(false)

  // External links
  telegramHelpUrl         String?
  telegramSupportUsername String?
  apiDocsBaseUrl          String?
}

// ─── User API ─────────────────────────────────────────────────────────────────

model UserApi {
  id              String    @id @default(cuid())
  userId          String    @unique
  apiKey          String    @unique
  isActive        Boolean   @default(true)
  rateLimit       Int       @default(100)
  refreshCount    Int       @default(0)
  lastRefreshedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshLogs UserApiRefreshLog[]
}

model UserApiRefreshLog {
  id        String   @id @default(cuid())
  userId    String
  createdAt DateTime @default(now())

  userApi UserApi @relation(fields: [userId], references: [userId], onDelete: Cascade)

  // Rate-limit window query: WHERE userId=X AND createdAt >= windowStart
  @@index([userId, createdAt])
}

// ─── User data & audit ────────────────────────────────────────────────────────

model UserData {
  id          String     @id @default(cuid())
  userId      String     @unique
  /// Always compare using UserStatus enum — never raw strings.
  status      UserStatus @default(ACTIVE)
  lastLogin   DateTime?
  apiCalls    Int        @default(0)
  lastApiCall DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
}

model UserAuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  adminId   String
  changes   Json?
  reason    String?
  createdAt DateTime @default(now())

  user  User @relation("AuditTarget",    fields: [userId],  references: [id])
  admin User @relation("AuditPerformer", fields: [adminId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([adminId, createdAt(sort: Desc)])
}
